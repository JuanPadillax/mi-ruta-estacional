---
// src/components/Methodology.astro
import { Image } from 'astro:assets';
import lupaImg from '../assets/Lupa.png';
import lapizImg from '../assets/lapiz.png';
import archivadorImg from '../assets/archivador.png';
import estrellaImg from '../assets/estrella.png';
---

<section class="methodology">
  <div class="deco deco-star-left">*</div>
  <div class="deco deco-star-right">*</div>

  <div class="section-header">
    <span class="subtitle">Metodología Lúdica</span>
    <h2 class="title">Un sistema, cuatro momentos continuos</h2>
    <p class="description">
      Solo espera a que la plataforma guíe el desarrollo del niño(a) integrando la<br>
      secuencia, el registro continuo y un sinfín de actividades de un modo simple, unificado y<br>
      comprimido.
    </p>
  </div>

  <div class="steps-container">
    <div class="step-item">
      <div class="icon-ring ring-orange">
        <Image src={lupaImg} alt="Explorar" class="step-icon" />
      </div>
      <h3 class="step-title text-orange">Explorar</h3>
    </div>

    <div class="step-item">
      <div class="icon-ring ring-blue">
        <Image src={lapizImg} alt="Registrar" class="step-icon" />
      </div>
      <h3 class="step-title text-blue">Registrar</h3>
    </div>

    <div class="step-item">
      <div class="icon-ring ring-green">
        <Image src={archivadorImg} alt="Habitar" class="step-icon" />
      </div>
      <h3 class="step-title text-green">Habitar</h3>
    </div>

    <div class="step-item">
      <div class="icon-ring ring-yellow">
        <Image src={estrellaImg} alt="Misiones" class="step-icon" />
      </div>
      <h3 class="step-title text-yellow">Misiones</h3>
    </div>
  </div>
</section>

<style>
  .methodology { 
    padding: 140px 5%; /* Se mantiene amplio */
    max-width: 1400px; /* Se mantiene amplio */
    margin: 0 auto; 
    text-align: center; 
    position: relative; 
  }

  .section-header { max-width: 900px; margin: 0 auto 80px auto; }
  
  /* --- TEXTOS HOMOLOGADOS CON ACTIVITIES --- */
  .subtitle { 
    color: var(--color-text-light); 
    font-size: 0.85rem; /* Igual a Activities */
    font-style: italic;
  }
  
  .title { 
    color: var(--color-primary-blue); 
    font-size: 2.2rem; /* Igual a Activities */
    margin: 15px 0 25px 0; 
    font-weight: 800; 
    letter-spacing: -0.5px;
    line-height: 1.1;
  }
  
  .description { 
    color: var(--color-text-dark); 
    line-height: 1.6; 
    font-weight: 500;
    font-size: 0.9rem; /* Igual a Activities */
  }

  .steps-container { 
    display: flex; 
    justify-content: center; 
    gap: 100px; /* Se mantiene la separación grande */
    flex-wrap: wrap; 
  }
  
  .step-item { 
    display: flex; 
    flex-direction: column; 
    align-items: center; 
    gap: 25px; 
  }
  
  /* --- ICONOS Y ANILLOS MANTENIDOS GRANDES --- */
  .icon-ring { 
    width: 180px; /* Se mantiene grande */
    height: 180px; /* Se mantiene grande */
    border-radius: 50%; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    border: 4px dashed; 
    background-color: white; 
    box-shadow: inset 0 0 0 12px white;
  }
  
  .ring-orange { border-color: var(--color-primary-orange); }
  .ring-blue { border-color: var(--color-primary-blue); }
  .ring-green { border-color: var(--color-primary-green); }
  .ring-yellow { border-color: var(--color-primary-yellow); }
  
  .step-title { 
    font-weight: 800; 
    font-size: 0.9rem; /* Igual al h4 de las tarjetas de Activities */
    margin-top: 5px; 
  }
  
  .text-orange { color: var(--color-primary-orange); }
  .text-blue { color: var(--color-primary-blue); }
  .text-green { color: var(--color-primary-green); }
  .text-yellow { color: var(--color-primary-yellow); }
  
  .step-icon { 
    width: 55%; /* Se mantiene la escala de la imagen interna */
    height: auto; 
    object-fit: contain; 
  }

  /* Decoraciones */
  .deco { position: absolute; font-size: 8rem; color: var(--color-primary-blue); opacity: 0.15; }
  .deco-star-left { top: 15%; left: 5%; }
  .deco-star-right { top: 15%; right: 5%; }

  @media (max-width: 768px) {
    .steps-container { gap: 50px; }
    .icon-ring { width: 130px; height: 130px; }
    .title { font-size: 1.8rem; }
  }
</style>
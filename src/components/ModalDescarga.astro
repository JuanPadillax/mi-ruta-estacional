---
// src/components/ModalDescarga.astro
---

<!-- 1. HTML DEL MODAL -->
<div id="downloadModal" class="modal-overlay">
  <div class="modal-content">
    <button class="close-modal" aria-label="Cerrar modal">&times;</button>
    <h2 class="modal-title">Descargar material educativo</h2>
    <p class="modal-subtitle">
      Selecciona el formato de tu preferencia para guardar e imprimir las fichas
      didácticas de esta actividad. Prepara tu material y dale continuidad a la
      experiencia en el aula o el hogar.
    </p>

    <div class="modal-options-header">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#7695c5"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"
        ></path>
      </svg>
      <span>Descargar como:</span>
    </div>

    <div class="format-options">
      <div class="format-card" data-format="png">
        <!-- Icono de imagen representado en un SVG limpio -->
        <svg width="45" height="45" viewBox="0 0 24 24" fill="#cbd5e1">
          <path
            d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"
          ></path>
        </svg>
        <span class="badge badge-png">PNG</span>
      </div>
      <div class="format-card" data-format="pdf">
        <!-- Icono de PDF representado en un SVG limpio -->
        <svg width="45" height="45" viewBox="0 0 24 24" fill="#f87171">
          <path
            d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"
          ></path>
        </svg>
        <span class="badge badge-pdf">PDF</span>
      </div>
    </div>

    <button id="confirmDownload" class="btn-confirm-download" disabled
      >Descargar</button
    >
  </div>
</div>

<!-- 2. LÓGICA DE PROGRAMACIÓN (TypeScript y Firebase compatible) -->
<script>
  import { auth } from "../lib/firebase";
  import { onAuthStateChanged } from "firebase/auth";

  document.addEventListener("DOMContentLoaded", () => {
    const modal = document.getElementById("downloadModal");
    const closeBtn = document.querySelector(".close-modal");
    const confirmBtn = document.getElementById(
      "confirmDownload",
    ) as HTMLButtonElement | null;
    const formatCards = document.querySelectorAll(".format-card");

    let selectedFormat: string | null = null;
    let currentPngFile: string | null = "";
    let currentPdfFile: string | null = "";
    let userSessionActive = false;

    // Si los elementos críticos no se encuentran en la página, se evita ejecutar el script
    if (!modal || !closeBtn || !confirmBtn) return;

    // Monitorear el estado de autenticación en tiempo real
    onAuthStateChanged(auth, (user) => {
      userSessionActive = !!user;
    });

    // Escuchar el clic de los botones de descarga de cada lámina
    document.querySelectorAll(".btn-download").forEach((button) => {
      button.addEventListener("click", () => {
        // Bloqueo inclusivo: si no está logueado, redirigir al login
        if (!userSessionActive) {
          alert(
            "¡Hola! El material interactivo de esta sección es exclusivo para nuestra red de escuelas asociadas. Inicia sesión o regístrate con tus datos escolares.",
          );
          window.location.href = "/login";
          return;
        }

        currentPngFile = button.getAttribute("data-png");
        currentPdfFile = button.getAttribute("data-pdf");

        modal.classList.add("active");

        selectedFormat = null;
        formatCards.forEach((c) => c.classList.remove("selected"));
        confirmBtn.disabled = true;
      });
    });

    // Controlar la selección visual del formato de archivo (PNG o PDF)
    formatCards.forEach((card) => {
      card.addEventListener("click", () => {
        formatCards.forEach((c) => c.classList.remove("selected"));
        card.classList.add("selected");
        selectedFormat = card.getAttribute("data-format");
        confirmBtn.disabled = false;
      });
    });

    // Evento para cerrar la interfaz del modal
    closeBtn.addEventListener("click", () => {
      modal.classList.remove("active");
    });

    // Acción para gatillar la descarga en el formato deseado
    confirmBtn.addEventListener("click", () => {
      if (!selectedFormat) return;

      const fileName =
        selectedFormat === "png" ? currentPngFile : currentPdfFile;
      if (!fileName) return;

      const downloadUrl = `/descargas/${fileName}`;
      const a = document.createElement("a");
      a.href = downloadUrl;
      a.download = fileName;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);

      modal.classList.remove("active");
    });
  });
</script>

<!-- 3. DISEÑO Y ESTILOS VISUALES -->
<style>
  /* =========================================================
     ESTILOS DEL MODAL DE DESCARGA
     ========================================================= */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }

  .modal-overlay.active {
    opacity: 1;
    pointer-events: all;
  }

  .modal-content {
    background: #ffffff;
    border-radius: 20px;
    padding: 40px;
    max-width: 600px;
    width: 90%;
    position: relative;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
    transform: translateY(20px);
    transition: transform 0.2s ease;
  }

  .modal-overlay.active .modal-content {
    transform: translateY(0);
  }

  .close-modal {
    position: absolute;
    top: 20px;
    right: 20px;
    background: none;
    border: none;
    font-size: 1.8rem;
    color: #a0a0a0;
    cursor: pointer;
    transition: color 0.2s;
  }

  .close-modal:hover {
    color: #333;
  }

  .modal-title {
    color: #7695c5;
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 15px 0;
    text-align: left;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
  }

  .modal-subtitle {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
    text-align: left;
    margin-bottom: 30px;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
  }

  .modal-options-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
    color: #555;
    font-weight: 600;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
  }

  .format-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 35px;
  }

  .format-card {
    border: 2px solid #e2e8f0;
    border-radius: 12px;
    padding: 30px 10px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 15px;
    background: #ffffff;
  }

  .format-card:hover {
    border-color: #cbd5e1;
    background: #f8fafc;
  }

  .format-card.selected {
    border-color: #7695c5;
    background-color: #f1f5f9;
    box-shadow: 0 4px 15px rgba(118, 149, 197, 0.15);
  }

  .badge {
    color: white;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
    font-weight: 700;
    margin-top: -15px;
    position: relative;
    letter-spacing: 0.5px;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
  }

  .badge-png {
    background: #c084fc;
  }

  .badge-pdf {
    background: #ef4444;
  }

  .btn-confirm-download {
    background-color: #7695c5;
    color: white;
    border: none;
    padding: 14px 0;
    width: 100%;
    max-width: 200px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 1rem;
    cursor: pointer;
    display: block;
    margin: 0 auto;
    transition:
      background-color 0.2s,
      transform 0.1s;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      sans-serif;
  }

  .btn-confirm-download:not(:disabled):hover {
    background-color: #6182b5;
    transform: translateY(-2px);
  }

  .btn-confirm-download:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
</style>

---
// src/components/Hero.astro
import { Image } from 'astro:assets';
import ninoImg from '../assets/niño.png'; 
---

<section class="hero">
  <div class="hero-content">
    <span class="subtitle">Sistema Modular de Aprendizaje</span>
    <h1 class="title">Una ruta diseñada para<br>aprender jugando.</h1>
    <p class="description">
      Bienvenidos a la plataforma oficial de "Mi Ruta Estacional". Un espacio digital diseñado para potenciar el desarrollo integral mediante dinámicas y experiencias didácticas, múltiples, prácticas y un acompañamiento lúdico de nuestra fauna nativa.
    </p>
    <div class="button-container">
      <a href="/login" class="btn btn-primary">Inicia Sesión</a>
      <a href="/registro" class="btn btn-secondary">Regístrate</a>
    </div>
  </div>

  <div class="hero-image-wrapper">
    <Image 
      src={ninoImg} 
      alt="Niño aprendiendo con libro" 
      class="hero-img"
    />
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    /* Aumentamos el padding superior (de 80px a 160px) para empujar toda la sección hacia abajo */
    padding: 160px 5% 100px; 
    max-width: 1400px;
    margin: 0 auto;
    gap: 40px;
    /* Altura mínima para que la sección respire y se centre verticalmente con el fondo */
    min-height: 85vh; 
    box-sizing: border-box;
  }

  .hero-content {
    flex: 1;
    max-width: 680px; /* Un poco más de ancho para el texto */
  }

  .subtitle {
    display: block;
    color: var(--color-text-light);
    font-size: 1.1rem;
    font-style: italic;
    margin-bottom: 15px;
  }

  .title {
    color: var(--color-primary-blue);
    /* Tamaño optimizado para 2 líneas */
    font-size: 3.2rem; 
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: 30px;
    letter-spacing: -2px;
  }

  .description {
    color: var(--color-text-dark);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.6;
    margin-bottom: 45px;
  }

  .button-container {
    display: flex;
    gap: 30px; /* Separación asegurada */
  }

  .btn {
    display: inline-block;
    text-align: center;
    text-decoration: none;
    padding: 18px 45px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    border: none;
    transition: transform 0.2s;
  }
  
  .btn:hover { transform: scale(1.05); }

  .btn-primary {
    background-color: var(--color-primary-blue);
    color: white;
    box-shadow: 0 6px 20px rgba(118, 152, 208, 0.4);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-primary-blue);
    border: 3px solid var(--color-primary-blue);
  }

  .hero-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center; 
    align-items: center;
  }

  .hero-img {
    width: 100%;
    max-width: 600px;
    height: auto;
    object-fit: contain;
    /* Mantenemos el tamaño grande */
    transform: scale(1.4); 
  }

  @media (max-width: 1024px) {
    .hero { 
      flex-direction: column; 
      text-align: center; 
      padding: 120px 5% 60px; /* Ajuste para tablets */
    }
    .hero-content { align-items: center; max-width: 100%; }
    .title { font-size: 2.8rem; }
  }
</style>
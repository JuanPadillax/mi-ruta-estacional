---
// src/components/Header.astro
import { Image } from 'astro:assets';
import marcaWebLogo from '../assets/marcaweb.png'; // Asegúrate de que la ruta a tus assets sea la correcta
---

<header class="header">
  <div class="header-container">
    <div class="logo-container">
      <a href="/" class="logo-link">
        <!-- Usamos el componente Image de Astro para cargar marcaweb.png optimizada -->
        <Image 
          src={marcaWebLogo} 
          alt="Logo Mi Ruta Estacional" 
          class="logo-img"
        />
      </a>
    </div>
    
    <div class="user-action">
      <button class="user-icon" aria-label="Perfil de usuario">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Contenedor principal fijo y con la sombra impecable */
  .header {
    position: sticky;
    top: 0;
    width: 100%;
    background-color: #FFFFFF;
    z-index: 1000;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  /* Contenedor interno que centra todo verticalmente */
  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center; 
    padding: 15px 5%;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
  }

  .logo-container {
    display: flex;
    align-items: center;
  }

  .logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  /* Controla el tamaño de tu logo aquí */
  .logo-img {
    height: 50px;       /* Ajusta la altura a lo que mejor le quede a tu diseño */
    width: auto;        /* Mantiene la proporción original para que no se deforme */
    object-fit: contain;
  }

  .user-action {
    display: flex;
    align-items: center; 
  }

  .user-icon {
    background-color: var(--color-primary-blue);
    color: white;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;
    transition: transform 0.2s;
  }
  
  .user-icon:hover { transform: scale(1.05); }
  .user-icon svg { width: 18px; height: 18px; }
</style>
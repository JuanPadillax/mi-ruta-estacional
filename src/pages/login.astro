---
// src/pages/login.astro
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import marcaWebLogo from "../assets/marcaweb.png";
import ninoImg from "../assets/niño.png";
---

<Layout title="Iniciar Sesión - Mi Ruta Estacional">
  <main class="login-page">
    <!-- Contenedor de contenido centralizado -->
    <div class="login-main-container">
      <!-- Columna Izquierda: Tarjeta de Login -->
      <div class="login-card-wrapper">
        <div class="login-card">
          <!-- Logo y Cabecera de la Tarjeta -->
          <div class="card-header">
            <Image
              src={marcaWebLogo}
              alt="Mi Ruta Estacional Logo"
              class="card-logo"
            />
            <h2 class="card-title">Bienvenida a tu espacio digital</h2>
            <p class="card-subtitle">
              Ingresa tus datos para acceder a las planificaciones y fichas
              descargables.
            </p>
          </div>

          <!-- Formulario de Entrada -->
          <form
            id="loginForm"
            class="login-form"
            onsubmit="event.preventDefault();"
          >
            <!-- Campo Correo -->
            <div class="input-group">
              <span class="input-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path
                    d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
                  ></path>
                  <polyline points="22,6 12,13 2,6"></polyline>
                </svg>
              </span>
              <input
                type="email"
                id="email"
                required
                placeholder="fernanda.sepulveda@gmail.com"
                class="login-input"
              />
            </div>

            <!-- Campo Contraseña -->
            <div class="input-group">
              <span class="input-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"
                  ></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
              </span>
              <input
                type="password"
                id="password"
                required
                placeholder="*************"
                class="login-input"
              />
            </div>

            <!-- Botón Ingresar -->
            <button type="submit" class="btn-submit"> Iniciar Sesión </button>
          </form>

          <!-- Enlaces de navegación interna -->
          <div class="card-navigation">
            <p class="register-hint">
              ¿Aún no tienes cuenta? <a href="/registro" class="link-blue"
                >Regístrate aquí.</a
              >
            </p>
            <a href="/recuperar" class="link-forgot"
              >¿Olvidaste tu contraseña?</a
            >
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Ilustración del Párvulo -->
      <div class="login-image-wrapper">
        <Image
          src={ninoImg}
          alt="Niño interactuando con el libro de Mi Ruta Estacional"
          class="login-illustration"
          loading="eager"
        />
      </div>
    </div>

    <!-- Footer de la página de acceso -->
    <footer class="login-footer">
      <div class="footer-container">
        <span class="footer-copy"
          >© 2026 Mi Ruta Estacional. Todos los derechos reservados.</span
        >
        <div class="footer-links">
          <a href="#">Soporte Educadoras</a>
          <span class="divider">|</span>
          <a href="#">Términos de Uso</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  import { auth } from "../lib/firebase";
  import {
    signInWithEmailAndPassword,
    setPersistence,
    browserLocalPersistence,
  } from "firebase/auth";
  // Importamos Firestore para consultar el rol del usuario
  import { getFirestore, doc, getDoc } from "firebase/firestore";

  const db = getFirestore();
  const loginForm = document.getElementById("loginForm");

  if (loginForm) {
    loginForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = (document.getElementById("email") as HTMLInputElement)
        .value;
      const password = (document.getElementById("password") as HTMLInputElement)
        .value;

      try {
        // Forzar persistencia local antes de firmar
        await setPersistence(auth, browserLocalPersistence);
        const userCredential = await signInWithEmailAndPassword(
          auth,
          email,
          password,
        );
        const uid = userCredential.user.uid;

        // 1. Buscamos el rol del usuario registrado en Firestore
        const userDocRef = doc(db, "usuarios", uid);
        const userDoc = await getDoc(userDocRef);

        if (userDoc.exists()) {
          const userData = userDoc.data();
          const rol = userData.rol;

          // 2. Redirección limpia reemplazando el historial según el rol correspondiente
          if (rol === "admin") {
            window.location.replace("/admin/dashboard");
          } else if (rol === "educadora") {
            window.location.replace("/mi-perfil-pedagogico");
          } else if (rol === "familia") {
            window.location.replace("/mi-perfil-familiar");
          } else {
            // Fallback por defecto si no coincide ningún rol estructurado
            window.location.replace("/");
          }
        } else {
          // Fallback si la cuenta existe en Auth pero no tiene documento en Firestore
          window.location.replace("/");
        }
      } catch (error: any) {
        console.error("Error de credenciales:", error.code);
        if (error.code === "auth/invalid-credential") {
          alert(
            "Correo o contraseña incorrectos. Por favor, verifica tus datos.",
          );
        } else {
          alert("Ocurrió un inconveniente al validar tus datos.");
        }
      }
    });
  }
</script>

<style>
  /* --- Estructura y Fondo de la Página --- */
  .login-page {
    min-height: calc(100vh - 80px);
    background-color: #fafafa;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  .login-main-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    width: 100%;
    padding: 40px 5%;
    margin: auto 0;
    gap: 80px;
  }

  /* --- Tarjeta del Formulario (BLOQUEADO PARA EVITAR QUE SE ACHIQUE) --- */
  .login-card-wrapper {
    flex: 0 0 500px;
    display: flex;
    justify-content: center;
    z-index: 5;
  }

  .login-card {
    background-color: #ffffff;
    border-radius: 40px;
    padding: 65px 55px;
    width: 100%;
    box-shadow: 0 12px 50px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.015);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-header {
    text-align: center;
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-logo {
    height: 58px;
    width: auto;
    object-fit: contain;
    margin-bottom: 28px;
  }

  .card-title {
    color: var(--color-primary-blue, #7191ca);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .card-subtitle {
    color: var(--color-text-light, #a0a0a0);
    font-size: 0.85rem;
    line-height: 1.5;
    max-width: 330px;
    margin: 0;
  }

  /* --- Inputs Estilo Underline --- */
  .login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .input-group {
    position: relative;
    border-bottom: 2px solid #e2e8f0;
    padding: 12px 0;
    display: flex;
    align-items: center;
    transition: border-color 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary-blue, #7191ca);
  }

  .input-icon {
    color: #fca311;
    display: flex;
    align-items: center;
    margin-right: 14px;
  }

  .input-icon svg {
    width: 20px;
    height: 20px;
  }

  .login-input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.95rem;
    color: var(--color-text-dark, #333333);
    padding: 4px 0;
  }

  .login-input::placeholder {
    color: #cbd5e1;
  }

  /* --- Botón del Formulario --- */
  .btn-submit {
    background-color: var(--color-primary-blue, #7191ca);
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 15px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    margin-top: 15px;
    transition:
      opacity 0.2s,
      transform 0.1s;
    box-shadow: 0 4px 14px rgba(118, 152, 208, 0.3);
  }

  .btn-submit:hover {
    opacity: 0.95;
  }

  .btn-submit:active {
    transform: scale(0.99);
  }

  /* --- Navegación Secundaria de la Tarjeta --- */
  .card-navigation {
    margin-top: 35px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .register-hint {
    font-size: 0.85rem;
    color: #94a3b8;
    margin: 0;
  }

  .link-blue {
    color: var(--color-primary-blue, #7191ca);
    text-decoration: none;
    font-weight: 700;
  }

  .link-blue:hover {
    text-decoration: underline;
  }

  .link-forgot {
    font-size: 0.8rem;
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.2s;
  }

  .link-forgot:hover {
    color: #94a3b8;
    text-decoration: underline;
  }

  /* --- Columna de Ilustración Flexible --- */
  .login-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .login-illustration {
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: scale(1.4) translateX(20px);
    transform-origin: center;
  }

  /* --- Footer --- */
  .login-footer {
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #e2e8f0;
    padding: 24px 5%;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary-blue, #7191ca);
  }

  .divider {
    font-size: 0.75rem;
    color: #e2e8f0;
  }

  /* --- Adaptabilidad Móvil --- */
  @media (max-width: 1100px) {
    .login-illustration {
      transform: scale(1.1) translateX(0);
    }
  }

  @media (max-width: 900px) {
    .login-main-container {
      flex-direction: column;
      text-align: center;
      padding: 40px 5%;
      gap: 40px;
    }

    .login-card-wrapper {
      flex: 1 1 auto;
      width: 100%;
      max-width: 500px;
    }

    .login-image-wrapper {
      max-width: 420px;
      margin-top: 20px;
    }

    .login-illustration {
      transform: scale(1) translateX(0);
    }

    .footer-container {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>

---
// src/pages/registro.astro
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import marcaWebLogo from "../assets/marcaweb.png";
import ninoImg from "../assets/niño.png";
---

<Layout title="Regístrate - Mi Ruta Estacional">
  <main class="login-page">
    <!-- Contenedor centralizado -->
    <div class="login-main-container">
      <!-- Columna Izquierda: Tarjeta de Registro -->
      <div class="login-card-wrapper">
        <div class="login-card">
          <!-- Logo y Cabecera de la Tarjeta -->
          <div class="card-header">
            <Image
              src={marcaWebLogo}
              alt="Mi Ruta Estacional Logo"
              class="card-logo"
            />
            <h2 class="card-title">Regístrate</h2>
            <p class="card-subtitle">
              Crea tu cuenta para comenzar a planificar y descargar todo el
              material de tu ruta estacional.
            </p>
          </div>

          <!-- Pestañas para Selección de Rol (Mantiene el diseño de marca) -->
          <div class="role-selector">
            <button type="button" class="role-tab active" data-role="educadora"
              >Educadora</button
            >
            <button type="button" class="role-tab" data-role="familia"
              >Familia (Padre/Apoderado)</button
            >
          </div>

          <!-- Formulario de Registro en Dos Columnas -->
          <form id="registerForm" class="login-form">
            <!-- Campo oculto para almacenar el rol seleccionado -->
            <input type="hidden" id="role" value="educadora" />

            <!-- Contenedor Grid para Dos Columnas -->
            <div class="form-grid">
              <!-- Columna Izquierda -->
              <div class="grid-column">
                <div class="input-group">
                  <input
                    type="text"
                    id="fullName"
                    required
                    placeholder="Nombre completo *"
                    class="login-input"
                  />
                </div>

                <div class="input-group">
                  <input
                    type="email"
                    id="email"
                    required
                    placeholder="Correo electrónico *"
                    class="login-input"
                  />
                </div>
              </div>

              <!-- Columna Derecha -->
              <div class="grid-column">
                <!-- Inputs Condicionales para Educadora -->
                <div id="educadoraFields" class="conditional-fields">
                  <div class="input-group">
                    <input
                      type="text"
                      id="schoolCode"
                      placeholder="Código de tu Escuela *"
                      class="login-input"
                    />
                  </div>
                  <div class="input-group">
                    <input
                      type="text"
                      id="educationLevel"
                      placeholder="Nivel educativo *"
                      class="login-input"
                    />
                  </div>
                </div>

                <!-- Inputs Condicionales para Familia -->
                <div id="familiaFields" class="conditional-fields hidden">
                  <div class="input-group">
                    <input
                      type="text"
                      id="studentCode"
                      placeholder="Código de Vinculación del Párvulo *"
                      class="login-input"
                    />
                  </div>
                  <div class="input-group">
                    <input
                      type="text"
                      id="relationship"
                      placeholder="Parentesco (Ej: Madre, Padre, Tutor) *"
                      class="login-input"
                    />
                  </div>
                </div>

                <div class="input-group">
                  <input
                    type="email"
                    id="confirmEmail"
                    required
                    placeholder="Confirmar correo electrónico *"
                    class="login-input"
                  />
                </div>
              </div>
            </div>

            <!-- Fila: Contraseña (Ancho completo) -->
            <div class="input-group full-width">
              <input
                type="password"
                id="password"
                required
                placeholder="Contraseña *"
                class="login-input"
              />
            </div>

            <!-- Botón Registrarse -->
            <button type="submit" class="btn-submit"> Regístrate </button>
          </form>

          <!-- Enlaces de navegación interna -->
          <div class="card-navigation">
            <p class="register-hint">
              ¿Ya tienes una cuenta? <a href="/login" class="link-blue"
                >Inicia sesión aquí.</a
              >
            </p>
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Ilustración del Párvulo -->
      <div class="login-image-wrapper">
        <Image
          src={ninoImg}
          alt="Niño interactuando con el libro de Mi Ruta Estacional"
          class="login-illustration"
          loading="eager"
        />
      </div>
    </div>

    <!-- Footer de la página -->
    <footer class="login-footer">
      <div class="footer-container">
        <span class="footer-copy"
          >© 2026 Mi Ruta Estacional. Todos los derechos reservados.</span
        >
        <div class="footer-links">
          <a href="#">Soporte Educadoras</a>
          <span class="divider">|</span>
          <a href="#">Términos de Uso</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  import { auth } from "../lib/firebase";
  import { createUserWithEmailAndPassword } from "firebase/auth";
  // Importamos Firestore para guardar la información
  import {
    getFirestore,
    doc,
    setDoc,
    collection,
    query,
    where,
    getDocs,
    updateDoc,
  } from "firebase/firestore";

  const db = getFirestore();
  const registerForm = document.getElementById("registerForm");
  const roleTabs = document.querySelectorAll(".role-tab");
  const roleInput = document.getElementById("role") as HTMLInputElement;

  const educadoraFields = document.getElementById("educadoraFields");
  const familiaFields = document.getElementById("familiaFields");

  // Lógica interactiva para alternar roles
  roleTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      roleTabs.forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");

      const selectedRole = tab.getAttribute("data-role") || "educadora";
      roleInput.value = selectedRole;

      if (selectedRole === "educadora") {
        educadoraFields?.classList.remove("hidden");
        familiaFields?.classList.add("hidden");

        // Hacemos obligatorios los inputs correspondientes
        (document.getElementById("schoolCode") as HTMLInputElement).required =
          true;
        (
          document.getElementById("educationLevel") as HTMLInputElement
        ).required = true;
        (document.getElementById("studentCode") as HTMLInputElement).required =
          false;
        (document.getElementById("relationship") as HTMLInputElement).required =
          false;
      } else {
        educadoraFields?.classList.add("hidden");
        familiaFields?.classList.remove("hidden");

        (document.getElementById("schoolCode") as HTMLInputElement).required =
          false;
        (
          document.getElementById("educationLevel") as HTMLInputElement
        ).required = false;
        (document.getElementById("studentCode") as HTMLInputElement).required =
          true;
        (document.getElementById("relationship") as HTMLInputElement).required =
          true;
      }
    });
  });

  // Asegurar requerimientos al iniciar
  if (roleInput.value === "educadora") {
    (document.getElementById("schoolCode") as HTMLInputElement).required = true;
    (document.getElementById("educationLevel") as HTMLInputElement).required =
      true;
  }

  // Lógica de Registro Dinámico
  if (registerForm) {
    registerForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      const role = roleInput.value;
      const fullName = (document.getElementById("fullName") as HTMLInputElement)
        .value;
      const email = (document.getElementById("email") as HTMLInputElement)
        .value;
      const confirmEmail = (
        document.getElementById("confirmEmail") as HTMLInputElement
      ).value;
      const password = (document.getElementById("password") as HTMLInputElement)
        .value;

      if (email !== confirmEmail) {
        alert("Los correos electrónicos ingresados no coinciden.");
        return;
      }

      try {
        let escuelaId = "";
        let alumnoDocRef = null;

        // --- VALIDACIONES CON FIRESTORE ---

        if (role === "educadora") {
          const schoolCode = (
            document.getElementById("schoolCode") as HTMLInputElement
          ).value.trim();

          // Buscar si el código de escuela existe
          const q = query(
            collection(db, "escuelas"),
            where("codigoAcceso", "==", schoolCode),
          );
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert("El código de escuela ingresado no es válido.");
            return;
          }

          // Tomar el ID de la primera escuela que coincida
          escuelaId = querySnapshot.docs[0].id;
        } else if (role === "familia") {
          const studentCode = (
            document.getElementById("studentCode") as HTMLInputElement
          ).value
            .trim()
            .toUpperCase();

          // Buscar si el código de vinculación del alumno existe
          const q = query(
            collection(db, "alumnos"),
            where("codigoVinculacion", "==", studentCode),
          );
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert(
              "El código de vinculación del párvulo no es válido. Solicítalo a tu educadora.",
            );
            return;
          }

          // Guardamos referencia de la ficha del alumno para actualizarla después
          alumnoDocRef = querySnapshot.docs[0].ref;
          escuelaId = querySnapshot.docs[0].data().escuelaId;
        }

        // --- CREACIÓN DE CUENTA EN AUTH ---
        const userCredential = await createUserWithEmailAndPassword(
          auth,
          email,
          password,
        );
        const uid = userCredential.user.uid;

        // --- GUARDADO DE DATOS EN FIRESTORE ---
        const userProfile: any = {
          nombre: fullName,
          email: email,
          rol: role,
          escuelaId: escuelaId,
          estado: "activo",
          fechaRegistro: new Date().toISOString(),
        };

        if (role === "educadora") {
          userProfile.nivelEducativo = (
            document.getElementById("educationLevel") as HTMLInputElement
          ).value;
        } else if (role === "familia") {
          userProfile.parentesco = (
            document.getElementById("relationship") as HTMLInputElement
          ).value;
          userProfile.alumnoId = alumnoDocRef?.id || "";
        }

        // Crear documento del usuario
        await setDoc(doc(db, "usuarios", uid), userProfile);

        // Si es familia, asociar el UID del apoderado a la ficha de su hijo
        if (role === "familia" && alumnoDocRef) {
          await updateDoc(alumnoDocRef, {
            padreAsociadoId: uid,
          });
        }

        alert("Cuenta creada exitosamente en la plataforma.");

        // Redirección dinámica según el rol
        if (role === "educadora") {
          window.location.href = "/mi-perfil-pedagogico";
        } else {
          window.location.href = "/mi-perfil-familiar";
        }
      } catch (error: any) {
        console.error("Error al registrar usuario:", error);
        if (error.code === "auth/email-already-in-use") {
          alert("Este correo electrónico ya se encuentra registrado.");
        } else if (error.code === "auth/weak-password") {
          alert("La contraseña es muy débil. Debe tener mínimo 6 caracteres.");
        } else {
          alert("Ocurrió un problema en el servidor al crear tu cuenta.");
        }
      }
    });
  }
</script>

<style>
  /* --- Estructura y Fondo de la Página --- */
  .login-page {
    min-height: calc(100vh - 80px);
    background-color: #fafafa;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  .login-main-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    width: 100%;
    padding: 40px 5%;
    margin: auto 0;
    gap: 60px;
  }

  /* --- Tarjeta del Registro (Espacio perfecto a 2 columnas) --- */
  .login-card-wrapper {
    flex: 0 0 650px;
    display: flex;
    justify-content: center;
    z-index: 5;
  }

  .login-card {
    background-color: #ffffff;
    border-radius: 40px;
    padding: 45px 50px;
    width: 100%;
    box-shadow: 0 12px 50px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.015);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-header {
    text-align: center;
    margin-bottom: 25px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    margin-bottom: 22px;
  }

  .card-title {
    color: var(--color-primary-blue, #7191ca);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .card-subtitle {
    color: var(--color-text-light, #a0a0a0);
    font-size: 0.82rem;
    line-height: 1.5;
    max-width: 420px;
    margin: 0;
  }

  /* Selector de Rol interactivo */
  .role-selector {
    display: flex;
    background-color: #f1f5f9;
    border-radius: 12px;
    padding: 6px;
    width: 100%;
    margin-bottom: 25px;
    gap: 5px;
  }

  .role-tab {
    flex: 1;
    border: none;
    background: transparent;
    padding: 10px 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: #64748b;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .role-tab.active {
    background-color: #ffffff;
    color: #7191ca;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  /* --- Formulario y Diseño de Columnas (Grid) --- */
  .login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    width: 100%;
  }

  .grid-column {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  /* Estructura del input con borde inferior */
  .input-group {
    position: relative;
    border-bottom: 2px solid #e2e8f0;
    padding: 10px 0;
    display: flex;
    align-items: center;
    transition: border-color 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary-blue, #7191ca);
  }

  .full-width {
    grid-column: span 2;
  }

  .conditional-fields {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .conditional-fields.hidden {
    display: none;
  }

  /* Inputs limpios */
  .login-input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.88rem;
    color: var(--color-text-dark, #333333);
    padding: 2px 0;
  }

  .login-input::placeholder {
    color: #cbd5e1;
  }

  /* --- Botón del Formulario --- */
  .btn-submit {
    background-color: var(--color-primary-blue, #7191ca);
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 15px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    margin-top: 15px;
    transition:
      opacity 0.2s,
      transform 0.1s;
    box-shadow: 0 4px 14px rgba(118, 152, 208, 0.3);
  }

  .btn-submit:hover {
    opacity: 0.95;
  }

  .btn-submit:active {
    transform: scale(0.99);
  }

  /* --- Navegación Secundaria --- */
  .card-navigation {
    margin-top: 25px;
    text-align: center;
  }

  .register-hint {
    font-size: 0.85rem;
    color: #94a3b8;
    margin: 0;
  }

  .link-blue {
    color: var(--color-primary-blue, #7191ca);
    text-decoration: none;
    font-weight: 700;
  }

  .link-blue:hover {
    text-decoration: underline;
  }

  /* --- Ilustración Flexible --- */
  .login-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .login-illustration {
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: scale(1.4) translateX(20px);
    transform-origin: center;
  }

  /* --- Footer --- */
  .login-footer {
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #e2e8f0;
    padding: 24px 5%;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary-blue, #7191ca);
  }

  .divider {
    font-size: 0.75rem;
    color: #e2e8f0;
  }

  /* --- Adaptabilidad Móvil --- */
  @media (max-width: 1200px) {
    .login-main-container {
      gap: 40px;
    }
    .login-card-wrapper {
      flex: 0 0 580px;
    }
    .login-illustration {
      transform: scale(1.2) translateX(0);
    }
  }

  @media (max-width: 1024px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 25px;
    }
    .full-width {
      grid-column: span 1;
    }
    .login-card-wrapper {
      flex: 0 0 460px;
    }
    .login-illustration {
      transform: scale(1.1) translateX(0);
    }
  }

  @media (max-width: 900px) {
    .login-main-container {
      flex-direction: column;
      text-align: center;
      padding: 40px 5%;
      gap: 40px;
    }

    .login-card-wrapper {
      flex: 1 1 auto;
      width: 100%;
      max-width: 600px;
    }

    .login-image-wrapper {
      max-width: 420px;
      margin-top: 20px;
    }

    .login-illustration {
      transform: scale(1) translateX(0);
    }

    .footer-container {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>

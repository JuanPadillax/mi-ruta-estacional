---
// src/pages/registro.astro
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import homepageLogo from "../assets/marcaweb.png";
import ninoImg from "../assets/niño.png";
---

<Layout title="Regístrate - Mi Ruta Estacional">
  <main class="login-page">
    <div class="login-main-container">
      <!-- Columna Izquierda: Tarjeta de Registro -->
      <div class="login-card-wrapper">
        <div class="login-card">
          <div class="card-header">
            <Image
              src={homepageLogo}
              alt="Mi Ruta Estacional Logo"
              class="card-logo"
            />
            <h2 class="card-title">Regístrate</h2>
            <p class="card-subtitle">
              Crea tu cuenta oficial para la red de escuelas asociadas de tu
              ruta estacional.
            </p>
          </div>

          <!-- Selector de Rol -->
          <div class="role-selector">
            <button type="button" class="role-tab active" data-role="educadora"
              >Educadora</button
            >
            <button type="button" class="role-tab" data-role="familia"
              >Familia (Padre/Apoderado)</button
            >
          </div>

          <!-- Formulario de Registro -->
          <form id="registerForm" class="login-form">
            <input type="hidden" id="role" value="educadora" />

            <!-- Contenedor Grid para Dos Columnas -->
            <div class="form-grid">
              <!-- Columna Izquierda -->
              <div class="grid-column">
                <div class="input-group">
                  <input
                    type="text"
                    id="fullName"
                    required
                    placeholder="Nombre completo *"
                    class="login-input"
                  />
                </div>

                <!-- Campo RUT Chileno -->
                <div class="input-group">
                  <input
                    type="text"
                    id="rut"
                    required
                    placeholder="RUT (Ej: 12.345.678-K) *"
                    class="login-input"
                    maxlength="12"
                  />
                </div>

                <!-- Correo Electrónico + Botón de Código -->
                <div class="input-group email-group">
                  <input
                    type="email"
                    id="email"
                    required
                    placeholder="Correo electrónico *"
                    class="login-input"
                  />
                  <button
                    type="button"
                    id="btnSendCode"
                    class="btn-inline-action">Enviar Código</button
                  >
                </div>

                <!-- Campo para ingresar el Código recibido -->
                <div id="verificationContainer" class="input-group hidden">
                  <input
                    type="text"
                    id="verificationCode"
                    placeholder="Ingresa el código enviado *"
                    class="login-input"
                    maxlength="6"
                  />
                  <button
                    type="button"
                    id="btnVerifyCode"
                    class="btn-inline-action success-color"
                    >Validar Código</button
                  >
                </div>
              </div>

              <!-- Columna Derecha -->
              <div class="grid-column">
                <!-- Inputs Condicionales para Educadora -->
                <div id="educadoraFields" class="conditional-fields">
                  <div class="input-group">
                    <input
                      type="text"
                      id="schoolCode"
                      placeholder="Código de tu Escuela *"
                      class="login-input"
                    />
                  </div>
                  <div class="input-group">
                    <input
                      type="text"
                      id="educationLevel"
                      placeholder="Nivel educativo *"
                      class="login-input"
                    />
                  </div>
                </div>

                <!-- Inputs Condicionales para Familia -->
                <div id="familiaFields" class="conditional-fields hidden">
                  <div class="input-group">
                    <input
                      type="text"
                      id="studentCode"
                      placeholder="Código de Vinculación del Párvulo *"
                      class="login-input"
                    />
                  </div>
                  <div class="input-group">
                    <input
                      type="text"
                      id="relationship"
                      placeholder="Parentesco (Ej: Madre, Padre, Tutor) *"
                      class="login-input"
                    />
                  </div>
                </div>

                <div class="input-group">
                  <input
                    type="email"
                    id="confirmEmail"
                    required
                    placeholder="Confirmar correo electrónico *"
                    class="login-input"
                  />
                </div>
              </div>
            </div>

            <!-- Contraseña -->
            <div class="input-group full-width">
              <input
                type="password"
                id="password"
                required
                placeholder="Contraseña (mínimo 6 caracteres) *"
                class="login-input"
              />
            </div>

            <!-- Botón Registrarse (Desactivado hasta verificar el correo) -->
            <button
              type="submit"
              id="btnSubmitRegister"
              class="btn-submit"
              disabled
            >
              Verifica tu correo para registrarte
            </button>
          </form>

          <div class="card-navigation">
            <p class="register-hint">
              ¿Ya tienes una cuenta? <a href="/login" class="link-blue"
                >Inicia sesión aquí.</a
              >
            </p>
          </div>
        </div>
      </div>

      <!-- Columna Derecha: Ilustración -->
      <div class="login-image-wrapper">
        <Image
          src={ninoImg}
          alt="Niño interactuando con el libro de Mi Ruta Estacional"
          class="login-illustration"
          loading="eager"
        />
      </div>
    </div>

    <footer class="login-footer">
      <div class="footer-container">
        <span class="footer-copy"
          >© 2026 Mi Ruta Estacional. Todos los derechos reservados.</span
        >
        <div class="footer-links">
          <a href="#">Soporte Educadoras</a>
          <span class="divider">|</span>
          <a href="#">Términos de Uso</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<script>
  import { auth } from "../lib/firebase";
  import { createUserWithEmailAndPassword } from "firebase/auth";
  import {
    getFirestore,
    doc,
    setDoc,
    getDoc, // 👈 Añadido getDoc a las importaciones para resolver el error en la línea 347
    collection,
    query,
    where,
    getDocs,
    updateDoc,
  } from "firebase/firestore";

  const db = getFirestore();
  const registerForm = document.getElementById(
    "registerForm",
  ) as HTMLFormElement | null;
  const roleTabs = document.querySelectorAll(".role-tab");
  const roleInput = document.getElementById("role") as HTMLInputElement;

  const educadoraFields = document.getElementById("educadoraFields");
  const familiaFields = document.getElementById("familiaFields");

  const rutInput = document.getElementById("rut") as HTMLInputElement;
  const emailInput = document.getElementById("email") as HTMLInputElement;
  const btnSendCode = document.getElementById(
    "btnSendCode",
  ) as HTMLButtonElement;
  const verificationContainer = document.getElementById(
    "verificationContainer",
  );
  const verificationCodeInput = document.getElementById(
    "verificationCode",
  ) as HTMLInputElement;
  const btnVerifyCode = document.getElementById(
    "btnVerifyCode",
  ) as HTMLButtonElement;
  const btnSubmitRegister = document.getElementById(
    "btnSubmitRegister",
  ) as HTMLButtonElement;

  let emailVerified = false;
  let generatedVerificationCode = "";

  // --- 1. LÓGICA DE FORMATEO Y VALIDACIÓN DE RUT CHILENO ---
  rutInput?.addEventListener("input", (e) => {
    let value = rutInput.value.replace(/[^0-9kK]/g, "");
    if (value.length > 1) {
      const dv = value.slice(-1).toUpperCase();
      const rutNums = value.slice(0, -1);

      // Aplicar puntos y guion
      let formatted = "";
      if (rutNums.length > 6) {
        formatted = rutNums.replace(/^(\d{1,2})(\d{3})(\d{3})$/, "$1.$2.$3");
      } else if (rutNums.length > 3) {
        formatted = rutNums.replace(/^(\d{1,3})(\d{3})$/, "$1.$2");
      } else {
        formatted = rutNums;
      }
      rutInput.value = formatted ? `${formatted}-${dv}` : dv;
    } else {
      rutInput.value = value.toUpperCase();
    }
  });

  function validarRutChileno(rutCompleto: string): boolean {
    if (!/^[0-9]+[-|‐][0-9kK]{1}$/.test(rutCompleto.replace(/\./g, "")))
      return false;
    const tmp = rutCompleto.replace(/\./g, "").split("-");
    let ruts = parseInt(tmp[0], 10);
    const dv = tmp[1].toUpperCase();

    let M = 0,
      S = 1;
    for (; ruts; ruts = Math.floor(ruts / 10)) {
      S = (S + (ruts % 10) * (9 - (M++ % 6))) % 11;
    }
    const dvEsperado = S ? (S - 1).toString() : "K";
    return dv === dvEsperado;
  }

  // --- 2. LÓGICA ENVIAR CÓDIGO DE VERIFICACIÓN AL CORREO ---
  btnSendCode?.addEventListener("click", async () => {
    const email = emailInput.value.trim();
    if (!email || !emailInput.checkValidity()) {
      alert("Por favor, ingresa un correo electrónico válido primero.");
      return;
    }

    btnSendCode.disabled = true;
    btnSendCode.textContent = "Enviando...";

    // Generamos un código de 6 dígitos al azar
    generatedVerificationCode = Math.floor(
      100000 + Math.random() * 900000,
    ).toString();

    try {
      // Guardamos el código temporalmente en Firestore asociado al correo para mayor seguridad
      await setDoc(doc(db, "codigos_verificacion", email.toLowerCase()), {
        codigo: generatedVerificationCode,
        fecha: new Date().toISOString(),
      });

      // ALERTA DE PRUEBA: En desarrollo simulamos la recepción para que veas el código
      alert(
        `[Modo Desarrollo] Se ha enviado un correo a ${email}. Código de verificación: ${generatedVerificationCode}`,
      );

      verificationContainer?.classList.remove("hidden");
      btnSendCode.textContent = "Reenviar Código";
      btnSendCode.disabled = false;
    } catch (error) {
      console.error("Error al generar código de verificación:", error);
      alert("Hubo un error al procesar el envío del código.");
      btnSendCode.disabled = false;
      btnSendCode.textContent = "Enviar Código";
    }
  });

  // --- 3. VALIDAR EL CÓDIGO INGRESADO ---
  btnVerifyCode?.addEventListener("click", async () => {
    const enteredCode = verificationCodeInput.value.trim();
    const email = emailInput.value.trim().toLowerCase();

    if (!enteredCode) {
      alert("Ingresa el código que recibiste.");
      return;
    }

    try {
      const codeDoc = await getDoc(doc(db, "codigos_verificacion", email));

      if (codeDoc.exists() && codeDoc.data().codigo === enteredCode) {
        emailVerified = true;
        alert("¡Correo electrónico verificado con éxito!");

        // Bloqueamos cambios en el email verificado
        emailInput.readOnly = true;
        verificationCodeInput.readOnly = true;
        btnVerifyCode.disabled = true;
        btnSendCode.disabled = true;

        // Desbloqueamos el botón de registro oficial
        btnSubmitRegister.disabled = false;
        btnSubmitRegister.textContent = "Regístrate";
      } else {
        alert(
          "El código ingresado es incorrecto. Por favor, verifica e inténtalo de nuevo.",
        );
      }
    } catch (error) {
      console.error(error);
      alert("Error al verificar el código.");
    }
  });

  // --- 4. ALTERNAR ROLES ---
  roleTabs.forEach((tab) => {
    tab.addEventListener("click", () => {
      roleTabs.forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");

      const selectedRole = tab.getAttribute("data-role") || "educadora";
      roleInput.value = selectedRole;

      if (selectedRole === "educadora") {
        educadoraFields?.classList.remove("hidden");
        familiaFields?.classList.add("hidden");
        (document.getElementById("schoolCode") as HTMLInputElement).required =
          true;
        (
          document.getElementById("educationLevel") as HTMLInputElement
        ).required = true;
        (document.getElementById("studentCode") as HTMLInputElement).required =
          false;
        (document.getElementById("relationship") as HTMLInputElement).required =
          false;
      } else {
        educadoraFields?.classList.add("hidden");
        familiaFields?.classList.remove("hidden");
        (document.getElementById("schoolCode") as HTMLInputElement).required =
          false;
        (
          document.getElementById("educationLevel") as HTMLInputElement
        ).required = false;
        (document.getElementById("studentCode") as HTMLInputElement).required =
          true;
        (document.getElementById("relationship") as HTMLInputElement).required =
          true;
      }
    });
  });

  // --- 5. LÓGICA DE REGISTRO COMPLETA EN FIREBASE ---
  if (registerForm) {
    registerForm.addEventListener("submit", async (e) => {
      e.preventDefault();

      if (!emailVerified) {
        alert(
          "Debes validar tu correo electrónico con el código de seguridad.",
        );
        return;
      }

      const rutVal = rutInput.value.trim();
      if (!validarRutChileno(rutVal)) {
        alert(
          "El RUT ingresado no es válido. Verifica los puntos, guion o el dígito verificador.",
        );
        return;
      }

      const role = roleInput.value;
      const fullName = (document.getElementById("fullName") as HTMLInputElement)
        .value;
      const email = emailInput.value.trim();
      const confirmEmail = (
        document.getElementById("confirmEmail") as HTMLInputElement
      ).value.trim();
      const password = (document.getElementById("password") as HTMLInputElement)
        .value;

      if (email !== confirmEmail) {
        alert("Los correos electrónicos ingresados no coinciden.");
        return;
      }

      try {
        let escuelaId = "";
        let alumnoDocRef = null;

        if (role === "educadora") {
          const schoolCode = (
            document.getElementById("schoolCode") as HTMLInputElement
          ).value.trim();
          const q = query(
            collection(db, "escuelas"),
            where("codigoAccesoEscuela", "==", schoolCode),
          );
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert("El código de escuela ingresado no es válido.");
            return;
          }
          escuelaId = querySnapshot.docs[0].id;
        } else if (role === "familia") {
          const studentCode = (
            document.getElementById("studentCode") as HTMLInputElement
          ).value
            .trim()
            .toUpperCase();
          const q = query(
            collection(db, "alumnos"),
            where("codigoVinculacion", "==", studentCode),
          );
          const querySnapshot = await getDocs(q);

          if (querySnapshot.empty) {
            alert("El código de vinculación del párvulo no es válido.");
            return;
          }

          alumnoDocRef = querySnapshot.docs[0].ref;
          escuelaId = querySnapshot.docs[0].data().escuelaId;
        }

        // Crear Cuenta en Authentication
        const userCredential = await createUserWithEmailAndPassword(
          auth,
          email,
          password,
        );
        const uid = userCredential.user.uid;

        // Guardar Perfil en Firestore
        const userProfile: any = {
          nombre: fullName,
          rut: rutVal,
          email: email,
          rol: role,
          escuelaId: escuelaId,
          estado: "activo",
          fechaRegistro: new Date().toISOString(),
        };

        if (role === "educadora") {
          userProfile.nivelEducativo = (
            document.getElementById("educationLevel") as HTMLInputElement
          ).value;
        } else if (role === "familia") {
          userProfile.parentesco = (
            document.getElementById("relationship") as HTMLInputElement
          ).value;
          userProfile.alumnoId = alumnoDocRef?.id || "";
        }

        await setDoc(doc(db, "usuarios", uid), userProfile);

        if (role === "familia" && alumnoDocRef) {
          await updateDoc(alumnoDocRef, {
            padreAsociadoId: uid,
          });
        }

        alert("¡Registro exitoso! Bienvenido a la plataforma.");
        window.location.href =
          role === "educadora"
            ? "/mi-perfil-pedagogico"
            : "/mi-perfil-familiar";
      } catch (error: any) {
        console.error(error);
        if (error.code === "auth/email-already-in-use") {
          alert("Este correo electrónico ya se encuentra registrado.");
        } else {
          alert("Ocurrió un error inesperado al procesar tu registro.");
        }
      }
    });
  }
</script>

<style>
  /* --- Se hereda todo el excelente estilo estacional anterior --- */
  .login-page {
    min-height: calc(100vh - 80px);
    background-color: #fafafa;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  .login-main-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px;
    width: 100%;
    padding: 40px 5%;
    margin: auto 0;
    gap: 60px;
  }

  .login-card-wrapper {
    flex: 0 0 650px;
    display: flex;
    justify-content: center;
    z-index: 5;
  }

  .login-card {
    background-color: #ffffff;
    border-radius: 40px;
    padding: 45px 50px;
    width: 100%;
    box-shadow: 0 12px 50px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.015);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-header {
    text-align: center;
    margin-bottom: 25px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    margin-bottom: 22px;
  }

  .card-title {
    color: var(--color-primary-blue, #7191ca);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .card-subtitle {
    color: var(--color-text-light, #a0a0a0);
    font-size: 0.82rem;
    line-height: 1.5;
    max-width: 420px;
    margin: 0;
  }

  .role-selector {
    display: flex;
    background-color: #f1f5f9;
    border-radius: 12px;
    padding: 6px;
    width: 100%;
    margin-bottom: 25px;
    gap: 5px;
  }

  .role-tab {
    flex: 1;
    border: none;
    background: transparent;
    padding: 10px 0;
    font-size: 0.85rem;
    font-weight: 700;
    color: #64748b;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .role-tab.active {
    background-color: #ffffff;
    color: #7191ca;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.05);
  }

  .login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    width: 100%;
  }

  .grid-column {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .input-group {
    position: relative;
    border-bottom: 2px solid #e2e8f0;
    padding: 10px 0;
    display: flex;
    align-items: center;
    transition: border-color 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary-blue, #7191ca);
  }

  .full-width {
    grid-column: span 2;
  }

  .conditional-fields {
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .conditional-fields.hidden {
    display: none;
  }

  /* Estilos específicos para verificación de correo */
  .email-group {
    display: flex;
    justify-content: space-between;
    gap: 10px;
  }

  .btn-inline-action {
    background-color: #f1f5f9;
    color: #475569;
    border: none;
    border-radius: 6px;
    padding: 6px 12px;
    font-size: 0.75rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
  }

  .btn-inline-action:hover:not(:disabled) {
    background-color: #e2e8f0;
    color: #1e293b;
  }

  .btn-inline-action.success-color {
    background-color: #7191ca;
    color: white;
  }

  .btn-inline-action.success-color:hover:not(:disabled) {
    background-color: #5f80b8;
  }

  .btn-inline-action:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .login-input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.88rem;
    color: var(--color-text-dark, #333333);
    padding: 2px 0;
  }

  .login-input::placeholder {
    color: #cbd5e1;
  }

  .btn-submit {
    background-color: var(--color-primary-blue, #7191ca);
    color: #ffffff;
    border: none;
    border-radius: 10px;
    padding: 15px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    margin-top: 15px;
    transition:
      opacity 0.2s,
      transform 0.1s;
    box-shadow: 0 4px 14px rgba(118, 152, 208, 0.3);
  }

  .btn-submit:hover:not(:disabled) {
    opacity: 0.95;
  }

  .btn-submit:disabled {
    background-color: #cbd5e1;
    cursor: not-allowed;
    box-shadow: none;
  }

  .card-navigation {
    margin-top: 25px;
    text-align: center;
  }

  .register-hint {
    font-size: 0.85rem;
    color: #94a3b8;
    margin: 0;
  }

  .link-blue {
    color: var(--color-primary-blue, #7191ca);
    text-decoration: none;
    font-weight: 700;
  }

  .link-blue:hover {
    text-decoration: underline;
  }

  .login-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 800px;
    position: relative;
    z-index: 1;
  }

  .login-illustration {
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: scale(1.4) translateX(20px);
    transform-origin: center;
  }

  .login-footer {
    width: 100%;
    background-color: #ffffff;
    border-top: 1px solid #e2e8f0;
    padding: 24px 5%;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #94a3b8;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary-blue, #7191ca);
  }

  .divider {
    font-size: 0.75rem;
    color: #e2e8f0;
  }

  .hidden {
    display: none !important;
  }

  /* --- Adaptabilidad Móvil --- */
  @media (max-width: 1200px) {
    .login-main-container {
      gap: 40px;
    }
    .login-card-wrapper {
      flex: 0 0 580px;
    }
    .login-illustration {
      transform: scale(1.2) translateX(0);
    }
  }

  @media (max-width: 1024px) {
    .form-grid {
      grid-template-columns: 1fr;
      gap: 25px;
    }
    .full-width {
      grid-column: span 1;
    }
    .login-card-wrapper {
      flex: 0 0 460px;
    }
    .login-illustration {
      transform: scale(1.1) translateX(0);
    }
  }

  @media (max-width: 900px) {
    .login-main-container {
      flex-direction: column;
      text-align: center;
      padding: 40px 5%;
      gap: 40px;
    }

    .login-card-wrapper {
      flex: 1 1 auto;
      width: 100%;
      max-width: 600px;
    }

    .login-image-wrapper {
      max-width: 420px;
      margin-top: 20px;

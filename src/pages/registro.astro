---
// src/pages/registro.astro
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import marcaWebLogo from '../assets/marcaweb.png';
import ninoImg from '../assets/niño.png';
---

<Layout title="Registrate - Mi Ruta Estacional">
  <main class="login-page">
    
    <!-- Contenedor de contenido centralizado (Ajustado para el formulario doble) -->
    <div class="login-main-container">
      
      <!-- Columna Izquierda: Tarjeta de Registro (Bloqueada para que no se achique) -->
      <div class="login-card-wrapper">
        <div class="login-card">
          
          <!-- Logo y Cabecera de la Tarjeta -->
          <div class="card-header">
            <Image 
              src={marcaWebLogo} 
              alt="Mi Ruta Estacional Logo" 
              class="card-logo"
            />
            <h2 class="card-title">Regístrate</h2>
            <p class="card-subtitle">
              Crea tu cuenta para comenzar a planificar y descargar todo el material de tu ruta estacional.
            </p>
          </div>

          <!-- Formulario de Registro en Dos Columnas -->
          <form id="registerForm" class="login-form">
            
            <!-- Fila Especial: Rol "Educadora" (Ocupa el ancho completo) -->
            <div class="input-group full-width">
              <span class="input-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="12" cy="7" r="4"></circle>
                </svg>
              </span>
              <input 
                type="text" 
                id="role" 
                value="Educadora" 
                readonly
                class="login-input readonly-input"
              />
              <span class="info-icon" title="Tu cuenta se registrará bajo el rol de Educadora">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"></circle>
                  <line x1="12" y1="16" x2="12" y2="12"></line>
                  <line x1="12" y1="8" x2="12.01" y2="8"></line>
                </svg>
              </span>
            </div>

            <!-- Contenedor Grid para Dos Columnas -->
            <div class="form-grid">
              
              <!-- Columna Izquierda -->
              <div class="grid-column">
                <div class="input-group">
                  <input 
                    type="text" 
                    id="fullName" 
                    required 
                    placeholder="Nombre completo *" 
                    class="login-input"
                  />
                </div>

                <div class="input-group">
                  <input 
                    type="text" 
                    id="childName" 
                    placeholder="Nombre del Párvulo (Opcional)" 
                    class="login-input"
                  />
                </div>

                <div class="input-group">
                  <input 
                    type="email" 
                    id="email" 
                    required 
                    placeholder="Correo electrónico *" 
                    class="login-input"
                  />
                </div>
              </div>

              <!-- Columna Derecha -->
              <div class="grid-column">
                <div class="input-group">
                  <input 
                    type="text" 
                    id="institution" 
                    required 
                    placeholder="Institución o Escuela *" 
                    class="login-input"
                  />
                </div>

                <div class="input-group">
                  <input 
                    type="text" 
                    id="educationLevel" 
                    required 
                    placeholder="Nivel educativo *" 
                    class="login-input"
                  />
                </div>

                <div class="input-group">
                  <input 
                    type="email" 
                    id="confirmEmail" 
                    required 
                    placeholder="Confirmar correo electrónico *" 
                    class="login-input"
                  />
                </div>
              </div>

            </div>

            <!-- Fila: Contraseña (Ancho completo) -->
            <div class="input-group full-width">
              <input 
                type="password" 
                id="password" 
                required 
                placeholder="Contraseña *" 
                class="login-input"
              />
            </div>

            <!-- Botón Registrarse -->
            <button type="submit" class="btn-submit">
              Regístrate
            </button>
          </form>

          <!-- Enlaces de navegación interna -->
          <div class="card-navigation">
            <p class="register-hint">
              ¿Ya tienes una cuenta? <a href="/login" class="link-blue">Inicia sesión aquí.</a>
            </p>
          </div>

        </div>
      </div>

      <!-- Columna Derecha: Ilustración del Párvulo (Mismo tamaño gigante) -->
      <div class="login-image-wrapper">
        <Image 
          src={ninoImg} 
          alt="Niño interactuando con el libro de Mi Ruta Estacional" 
          class="login-illustration"
          loading="eager"
        />
      </div>

    </div>

    <!-- Footer de la página -->
    <footer class="login-footer">
      <div class="footer-container">
        <span class="footer-copy">© 2026 Mi Ruta Estacional. Todos los derechos reservados.</span>
        <div class="footer-links">
          <a href="#">Soporte Educadoras</a>
          <span class="divider">|</span>
          <a href="#">Términos de Uso</a>
        </div>
      </div>
    </footer>

  </main>
</Layout>

<script>
  import { auth } from '../lib/firebase';
  import { createUserWithEmailAndPassword } from 'firebase/auth';

  const registerForm = document.getElementById('registerForm');

  if (registerForm) {
    registerForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const email = (document.getElementById('email') as HTMLInputElement).value;
      const confirmEmail = (document.getElementById('confirmEmail') as HTMLInputElement).value;
      const password = (document.getElementById('password') as HTMLInputElement).value;

      if (email !== confirmEmail) {
        alert('Los correos electrónicos ingresados no coinciden.');
        return;
      }

      try {
        // Registro básico con Firebase Auth
        await createUserWithEmailAndPassword(auth, email, password);
        alert('Cuenta creada exitosamente.');
        window.location.href = '/'; 
      } catch (error: any) {
        console.error("Error al registrar usuario:", error.code);
        if (error.code === 'auth/email-already-in-use') {
          alert('Este correo electrónico ya se encuentra registrado.');
        } else if (error.code === 'auth/weak-password') {
          alert('La contraseña es muy débil. Intenta con al menos 6 caracteres.');
        } else {
          alert('Ocurrió un problema al crear tu cuenta.');
        }
      }
    });
  }
</script>

<style>
  /* --- Estructura y Fondo de la Página --- */
  .login-page {
    min-height: calc(100vh - 80px);
    background-color: #FAFAFA;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    position: relative;
    overflow-x: hidden;
  }

  .login-main-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1440px; 
    width: 100%;
    padding: 40px 5%;
    margin: auto 0;
    gap: 60px; 
  }

  /* --- Tarjeta del Registro (Bloqueada en ancho óptimo para 2 columnas) --- */
  .login-card-wrapper {
    /* flex-basis sube a 650px para dar espacio perfecto a los inputs paralelos */
    flex: 0 0 650px; 
    display: flex;
    justify-content: center;
    z-index: 5; 
  }

  .login-card {
    background-color: #FFFFFF;
    border-radius: 40px;
    padding: 55px 50px;
    width: 100%;
    box-shadow: 0 12px 50px rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.015);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-header {
    text-align: center;
    margin-bottom: 35px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .card-logo {
    height: 52px;
    width: auto;
    object-fit: contain;
    margin-bottom: 22px;
  }

  .card-title {
    color: var(--color-primary-blue, #7191ca);
    font-size: 1.35rem;
    font-weight: 700;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .card-subtitle {
    color: var(--color-text-light, #a0a0a0);
    font-size: 0.82rem;
    line-height: 1.5;
    max-width: 420px;
    margin: 0;
  }

  /* --- Formulario y Diseño de Columnas (Grid) --- */
  .login-form {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 25px;
  }

  .form-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px; /* Separación horizontal entre columnas */
    width: 100%;
  }

  .grid-column {
    display: flex;
    flex-direction: column;
    gap: 25px; /* Separación vertical interna */
  }

  /* Estructura del input con borde inferior */
  .input-group {
    position: relative;
    border-bottom: 2px solid #E2E8F0;
    padding: 10px 0;
    display: flex;
    align-items: center;
    transition: border-color 0.2s;
  }

  .input-group:focus-within {
    border-color: var(--color-primary-blue, #7191ca);
  }

  .full-width {
    grid-column: span 2;
  }

  /* Estilos específicos para el campo estático de Rol (Educadora) */
  .input-icon {
    color: #FCA311;
    display: flex;
    align-items: center;
    margin-right: 14px;
  }

  .input-icon svg {
    width: 20px;
    height: 20px;
  }

  .info-icon {
    color: #CBD5E1;
    display: flex;
    align-items: center;
    cursor: help;
  }

  .info-icon svg {
    width: 18px;
    height: 18px;
  }

  .readonly-input {
    color: var(--color-primary-blue, #7191ca) !important;
    font-weight: 600;
    cursor: default;
  }

  /* Inputs limpios */
  .login-input {
    width: 100%;
    border: none;
    outline: none;
    background: transparent;
    font-size: 0.88rem;
    color: var(--color-text-dark, #333333);
    padding: 2px 0;
  }

  .login-input::placeholder {
    color: #CBD5E1;
  }

  /* --- Botón del Formulario --- */
  .btn-submit {
    background-color: var(--color-primary-blue, #7191ca);
    color: #FFFFFF;
    border: none;
    border-radius: 10px;
    padding: 15px;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    width: 100%;
    margin-top: 15px;
    transition: opacity 0.2s, transform 0.1s;
    box-shadow: 0 4px 14px rgba(118, 152, 208, 0.3);
  }

  .btn-submit:hover {
    opacity: 0.95;
  }

  .btn-submit:active {
    transform: scale(0.99);
  }

  /* --- Navegación Secundaria de la Tarjeta --- */
  .card-navigation {
    margin-top: 30px;
    text-align: center;
  }

  .register-hint {
    font-size: 0.85rem;
    color: #94A3B8;
    margin: 0;
  }

  .link-blue {
    color: var(--color-primary-blue, #7191ca);
    text-decoration: none;
    font-weight: 700;
  }

  .link-blue:hover {
    text-decoration: underline;
  }

  /* --- Columna de Ilustración Flexible (Igual que en login) --- */
  .login-image-wrapper {
    flex: 1; 
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 800px; 
    position: relative;
    z-index: 1;
  }

  .login-illustration {
    width: 100%;
    height: auto;
    object-fit: contain;
    transform: scale(1.4) translateX(20px); 
    transform-origin: center;
  }

  /* --- Footer --- */
  .login-footer {
    width: 100%;
    background-color: #FFFFFF;
    border-top: 1px solid #E2E8F0;
    padding: 24px 5%;
  }

  .footer-container {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .footer-copy {
    font-size: 0.75rem;
    color: #94A3B8;
  }

  .footer-links {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .footer-links a {
    font-size: 0.75rem;
    color: #94A3B8;
    text-decoration: none;
    transition: color 0.2s;
  }

  .footer-links a:hover {
    color: var(--color-primary-blue, #7191ca);
  }

  .divider {
    font-size: 0.75rem;
    color: #E2E8F0;
  }

  /* --- Adaptabilidad Móvil --- */
  @media (max-width: 1200px) {
    .login-main-container {
      gap: 40px;
    }
    .login-card-wrapper {
      flex: 0 0 580px; /* Ajuste sutil para pantallas intermedias */
    }
    .login-illustration {
      transform: scale(1.2) translateX(0);
    }
  }

  @media (max-width: 1024px) {
    .form-grid {
      grid-template-columns: 1fr; /* Colapsa las 2 columnas a 1 sola si la pantalla se reduce de ancho */
      gap: 25px;
    }
    .full-width {
      grid-column: span 1;
    }
    .login-card-wrapper {
      flex: 0 0 460px;
    }
    .login-illustration {
      transform: scale(1.1) translateX(0);
    }
  }

  @media (max-width: 900px) {
    .login-main-container {
      flex-direction: column;
      text-align: center;
      padding: 40px 5%;
      gap: 40px;
    }

    .login-card-wrapper {
      flex: 1 1 auto; 
      width: 100%;
      max-width: 600px;
    }

    .login-image-wrapper {
      max-width: 420px;
      margin-top: 20px;
    }

    .login-illustration {
      transform: scale(1) translateX(0);
    }

    .footer-container {
      flex-direction: column;
      gap: 12px;
      text-align: center;
    }
  }
</style>
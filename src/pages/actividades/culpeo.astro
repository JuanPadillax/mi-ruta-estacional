---
// src/pages/actividades/culpeo.astro
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import culpeoImg from '../../assets/culpeo.png';

// Importamos la imagen de la estrella desde tu carpeta de assets
import estrellaImg from '../../assets/estrella.png';
---

<Layout title="Estación de Otoño - Zorro Culpeo">
  <main class="culpeo-page">
    
    <!-- Hero Section con el diseño original absoluto e intocable de escritorio -->
    <section class="hero-section">
      <div class="hero-content">
        <span class="season-badge">Estación de Otoño</span>
        <h1 class="main-title">Explorar e identificar con el<br>Zorro Culpeo</h1>
        <p class="hero-description">
          Bienvenido al espacio digital del Tomo 1. Aquí encontrarás el material imprimible, las pautas de aula y las misiones de exploración diseñadas para conectar las experiences lúdicas del patio y el hogar con el acompañamiento de nuestra fauna nativa.
        </p>
        <a href="/" class="btn-back">Volver al Inicio</a>
      </div>
      
      <div class="hero-image-container">
        <Image src={culpeoImg} alt="Zorro Culpeo en tamaño grande" class="hero-character" />
      </div>
    </section>

    <!-- SECCIÓN 1: Reconocimiento y Bienvenida -->
    <section class="categories-wrapper">
      <div class="category-block">
        <div class="category-banner">Reconocimiento y Bienvenida</div>
        <div class="cards-grid">
          
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Crea a tu compañero!</h3>
                <p>Ficha para recortar y armar tu propio Zorrito Culpeo. Promueve el sentido de pertenencia, la identidad y la motricidad fina.</p>
              </div>
            </div>
            <a href="/actividades/crea-tu-companero" class="btn-view bg-orange-btn">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Mi plato favorito!</h3>
                <p>Actividad lúdica centrada en reconocer los cambios estacionales en la alimentación diaria y expresar preferencias individuales.</p>
              </div>
            </div>
            <a href="/actividades/mi-plato-favorito" class="btn-view bg-orange-btn">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="star-badge">
              <Image src={estrellaImg} alt="Misión Especial" class="star-graphic" />
            </div>
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-yellow-title">¡Diseña tu mapa base!</h3>
                <p>Hito especial para ejecutar en el hogar en volumen junto a la familia, promoviendo la vinculación comunitaria y escolar.</p>
              </div>
            </div>
            <a href="/actividades/disena-tu-mapa-base" class="btn-view bg-yellow-btn link-btn-style">Ver</a>
          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 2: Desafíos de Lógica y Atención -->
    <section class="categories-wrapper">
      <div class="category-block">
        <div class="category-banner">Desafíos de Lógica y Atención</div>
        <div class="cards-grid">
          
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Encuentra al intruso!</h3>
                <p>Actividad de atención selectiva y categorización. El párvulo debe identificar de forma autónoma qué elemento rompe el patrón lógico o geográfico.</p>
              </div>
            </div>
            <a href="/actividades/encuentra-el-intruso" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Sombras mágicas!</h3>
                <p>Fortalece la asociación cognitiva, la percepción espacial y el control del trazo, ejercitando la coordinación óculo-manual necesaria para la preescritura.</p>
              </div>
            </div>
            <a href="/actividades/sombras-magicas" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Conteo de tesoros!</h3>
                <p>Promueve el desarrollo del pensamiento matemático a través de la cuantificación y la correspondencia término a término con elementos reales del bosque.</p>
              </div>
            </div>
            <a href="/actividades/conteo-de-tesoros" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 3: Exploración Sensorial y Entorno -->
    <section class="categories-wrapper">
      <div class="category-block">
        <div class="category-banner">Exploración Sensorial y Entorno</div>
        <div class="cards-grid">
          
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Abriga al árbol!</h3>
                <p>Experiencia de expresión artística libre mediante dactilopintura. Fortalece la musculatura de la mano y los dedos, clave para la preescritura.</p>
              </div>
            </div>
            <a href="/actividades/abriga-al-arbol" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Sigue la caída!</h3>
                <p>Ejercita la disociación de la muñeca y el control del trazo mediante el seguimiento de líneas curvas continuas que simulan la trayectoria de las hojas.</p>
              </div>
            </div>
            <a href="/actividades/sigue-la-caida" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="star-badge">
              <Image src={estrellaImg} alt="Misión Especial" class="star-graphic" />
            </div>
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-yellow-title">Expedición a los árboles</h3>
                <p>Hito de aprendizaje experiencial al aire libre para activar los sentidos, interactuar con el clima otoñal y recolectar tesoros orgánicos reales.</p>
              </div>
            </div>
            <a href="/actividades/expedicion-a-los-arboles" class="btn-view bg-yellow-btn link-btn-style">Ver</a>
          </div>

        </div>
      </div>
    </section>

    <!-- SECCIÓN 4: Recapitulación y Cierre -->
    <section class="categories-wrapper">
      <div class="category-block">
        <div class="category-banner">Recapitulación y Cierre</div>
        <div class="cards-grid">
          
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Ayuda a nuestros amigos!</h3>
                <p>Actividad lúdica de laberintos y resolución de problemas que fomenta la orientación espacial en el entorno del bosque nativo.</p>
              </div>
            </div>
            <a href="/actividades/ayuda-a-nuestros-amigos" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <!-- Tarjeta 2: ¡Pillemos al zorrito! (CORREGIDA CON ENLACE ACTIVO) -->
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Pillemos al zorrito!</h3>
                <p>Actividad lúdica de búsqueda y percepción visual adaptada al entorno natural del bosque nativo chileno.</p>
              </div>
            </div>
            <!-- Cambiado de <button> a <a> apuntando a la nueva página -->
            <a href="/actividades/pillemos-al-zorrito" class="btn-view bg-orange-btn link-btn-style">Ver</a>
          </div>

          <div class="activity-card-container">
            <div class="star-badge">
              <Image src={estrellaImg} alt="Misión Especial" class="star-graphic" />
            </div>
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-yellow-title">Hora del cuento</h3>
                <p>Experiencia narrativa e interactiva titulada "El viento frío y el calor del hogar", diseñada para trabajar la transición de la estación.</p>
              </div>
            </div>
            <a href="/actividades/hora-del-cuento" class="btn-view bg-yellow-btn link-btn-style">Ver</a>
          </div>

        </div>
      </div>
    </section>

  </main>

  <footer class="site-footer">
    <div class="footer-content">
      <p>© 2026 Mi Ruta Estacional. Todos los derechos reservados.</p>
      <p class="footer-links">Soporte Educadoras | Términos de Uso</p>
    </div>
  </footer>
</Layout>

<style>
  .culpeo-page {
    max-width: 1300px;
    margin: 0 auto;
    padding: 60px 5% 0 5%;
  }

  /* --- HERO EN ESCRITORIO ORIGINAL --- */
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 450px;
    position: relative;
    margin-bottom: 80px;
    gap: 20px;
  }
  
  .hero-content { 
    max-width: 750px; 
    text-align: left;
    position: relative;
    z-index: 2;
  }
  
  .season-badge { 
    font-size: 1.15rem; 
    color: #b5b5b5; 
    font-style: italic;
    display: block; 
    margin-bottom: 12px;
    font-weight: 500;
  }
  
  /* Arreglo estricto para las 2 líneas */
  .main-title { 
    font-size: 2.8rem; 
    font-weight: 700; 
    color: #f07f3e; 
    line-height: 1.2; 
    margin: 0 0 25px 0; 
    white-space: pre-line; 
    width: 100%;
    display: block;
  }
  
  .hero-description { 
    color: #333; 
    font-size: 1.1rem; 
    line-height: 1.6; 
    margin-bottom: 40px; 
    font-weight: 400;
    max-width: 550px;
  }

  .btn-back { 
    background: linear-gradient(to bottom, #f39237, #ee7623); 
    color: white; 
    padding: 12px 35px; 
    border-radius: 8px; 
    text-decoration: none; 
    font-weight: 600; 
    font-size: 0.95rem;
    display: inline-block; 
    box-shadow: 0 5px 0px #cf6517, 0 8px 15px rgba(0, 0, 0, 0.15);
    transition: all 0.1s ease;
  }
  .btn-back:hover {
    transform: translateY(2px);
    box-shadow: 0 3px 0px #cf6517, 0 5px 10px rgba(0, 0, 0, 0.15);
  }

  /* Posicionamiento absoluto original para el zorro a la derecha */
  .hero-image-container {
    position: absolute;
    right: -40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
  }
  
  .hero-character { 
    width: 550px; 
    height: auto; 
    object-fit: contain;
  }

  /* --- SECCIÓN DE TARJETAS --- */
  .category-block { margin-top: 40px; margin-bottom: 40px; }
  
  .category-banner {
    background: #f39237; 
    color: white; 
    padding: 14px 30px; 
    border-radius: 25px;
    font-weight: 700; 
    font-size: 1.15rem; 
    text-align: center; 
    margin-bottom: 50px;
  }
  
  .cards-grid {
    display: flex; 
    gap: 35px; 
    justify-content: space-between;
  }

  .activity-card-container {
    width: 31%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .activity-card {
    background: #ffffff; 
    border-radius: 28px; 
    width: 100%;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.07); 
    border: 1px solid #f2f2f2;
    overflow: hidden; 
    display: flex;
    flex-direction: column;
    min-height: 380px; 
  }

  .card-image-wrapper {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  
  .card-image-placeholder {
    width: 100%; 
    height: 100%; 
    background: #d4d4d4; 
  }

  .card-info {
    padding: 25px 20px;
    text-align: center;
  }

  .card-info h3 {
    font-size: 1.3rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .text-orange-title { color: #f07f3e; }
  .text-yellow-title { color: #ebba34; }

  .card-info p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    margin: 0;
    font-weight: 400;
  }

  /* Base común de diseño para botones y enlaces de tipo botón */
  .btn-view, .link-btn-style {
    border: none;
    padding: 11px 0;
    width: 140px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    cursor: pointer;
    margin-top: 25px; 
    transition: transform 0.1s ease;
    text-align: center;
    text-decoration: none;
    line-height: 1.2;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    box-sizing: border-box;
  }
  
  .btn-view:hover, .link-btn-style:hover { transform: scale(1.05); }

  .bg-orange-btn {
    background-color: #f07f3e;
    box-shadow: 0 4px 0px #cf6517;
  }
  .bg-yellow-btn {
    background-color: #fcd054;
    box-shadow: 0 4px 0px #dca51a;
  }

  /* Ajustes para el contenedor de la estrella */
  .star-badge {
    position: absolute;
    top: -40px;     
    right: -40px;   
    z-index: 10;
    width: 140px;    
    height: 140px;
    pointer-events: none; 
  }

  .star-graphic {
    width: 100% !important;
    height: auto !important;
    object-fit: contain;
    filter: drop-shadow(0px 6px 10px rgba(0,0,0,0.15));
  }

  /* --- ESTILOS DEL SITE FOOTER --- */
  .site-footer {
    background-color: #f39237;
    color: white;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    margin-top: 100px;
    padding: 22px 0;
    box-sizing: border-box;
  }

  .footer-content {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 5%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.85rem;
  }

  /* ==========================================================================
     MEDIA QUERIES
     ========================================================================= */

  @media (max-width: 1100px) {
    .main-title { font-size: 2.4rem; }
    .hero-character { width: 440px; }
    .cards-grid { gap: 20px; }
  }

  @media (max-width: 850px) {
    .culpeo-page { padding: 40px 6% 0 6%; }
    .hero-section { flex-direction: column; text-align: center; gap: 35px; min-height: auto; }
    .hero-content { max-width: 100%; display: flex; flex-direction: column; align-items: center; }
    .main-title { font-size: 2.2rem; white-space: normal; }
    
    .hero-image-container {
      position: relative;
      right: auto;
      top: auto;
      transform: none;
      margin: 0 auto;
      max-width: 360px;
    }

    .hero-character { width: 100%; }
    .cards-grid { flex-direction: column; align-items: center; gap: 50px; }
    .activity-card-container { width: 100%; max-width: 420px; }
    .activity-card { min-height: auto; }
    .star-badge { width: 105px; height: 105px; top: -25px; right: -25px; }
    
    .footer-content {
      flex-direction: column;
      gap: 10px;
      text-align: center;
    }
  }
</style>
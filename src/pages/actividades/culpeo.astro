---
// src/pages/actividades/culpeo.astro
import Layout from '../../layouts/Layout.astro';
import { Image } from 'astro:assets';
import culpeoImg from '../../assets/culpeo.png';

// Importamos la imagen de la estrella desde tu carpeta de assets
import estrellaImg from '../../assets/estrella.png';
---

<Layout title="Estación de Otoño - Zorro Culpeo">
  <main class="culpeo-page">
    
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="hero-content">
        <span class="season-badge">Estación de Otoño</span>
        <h1 class="main-title">
          Explorar e identificar con el<br>Zorro Culpeo
        </h1>
        <p class="hero-description">
          Bienvenido al espacio digital del Tomo 1. Aquí encontrarás el material imprimible, las pautas de aula y las misiones de exploración diseñadas para conectar las experiences lúdicas del patio y el hogar con el acompañamiento de nuestra fauna nativa.
        </p>
        <a href="/" class="btn-back">Volver al Inicio</a>
      </div>
      
      <div class="hero-image-container">
        <Image src={culpeoImg} alt="Zorro Culpeo en tamaño grande" class="hero-character" />
      </div>
    </section>

    <!-- Sección del Grid de Actividades -->
    <section id="actividades-grid" class="categories-wrapper">
      <div class="category-block">
        <div class="category-banner">Reconocimiento y Bienvenida</div>
        <div class="cards-grid">
          
          <!-- Tarjeta 1 -->
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Crea a tu compañero!</h3>
                <p>Ficha para recortar y armar tu propio Zorrito Culpeo. Promueve el sentido de pertenencia, la identidad y la motricidad fina.</p>
              </div>
            </div>
            <button class="btn-view bg-orange-btn">Ver</button>
          </div>

          <!-- Tarjeta 2 -->
          <div class="activity-card-container">
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-orange-title">¡Mi plato favorito!</h3>
                <p>Actividad lúdica centrada en reconocer los cambios estacionales en la alimentación diaria y expresar preferencias individuales.</p>
              </div>
            </div>
            <button class="btn-view bg-orange-btn">Ver</button>
          </div>

          <!-- Tarjeta 3 (Con el componente Image para la estrella) -->
          <div class="activity-card-container">
            <div class="star-badge">
              <Image src={estrellaImg} alt="Misión Especial" class="star-graphic" />
            </div>
            <div class="activity-card">
              <div class="card-image-wrapper">
                <div class="card-image-placeholder"></div>
              </div>
              <div class="card-info">
                <h3 class="text-yellow-title">¡Diseña tu mapa base!</h3>
                <p>Hito especial para ejecutar en el hogar en volumen junto a la familia, promoviendo la vinculación comunitaria y escolar.</p>
              </div>
            </div>
            <button class="btn-view bg-yellow-btn">Ver</button>
          </div>

        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .culpeo-page {
    max-width: 1300px;
    margin: 0 auto;
    padding: 60px 5% 100px 5%;
  }

  /* Estructura del Hero */
  .hero-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 450px;
    position: relative;
    margin-bottom: 80px;
    gap: 20px;
  }
  
  .hero-content { 
    max-width: 750px; 
    text-align: left;
    position: relative;
    z-index: 2;
  }
  
  .season-badge { 
    font-size: 1.15rem; 
    color: #b5b5b5; 
    font-style: italic;
    display: block; 
    margin-bottom: 12px;
    font-weight: 500;
  }
  
  .main-title { 
    font-size: 2.8rem; 
    font-weight: 700; 
    color: #f07f3e; 
    line-height: 1.2; 
    margin: 0 0 25px 0; 
  }
  
  .hero-description { 
    color: #333; 
    font-size: 1.1rem; 
    line-height: 1.6; 
    margin-bottom: 40px; 
    font-weight: 400;
    max-width: 550px;
  }

  .btn-back { 
    background: linear-gradient(to bottom, #f39237, #ee7623); 
    color: white; 
    padding: 12px 35px; 
    border-radius: 8px; 
    text-decoration: none; 
    font-weight: 600; 
    font-size: 0.95rem;
    display: inline-block; 
    box-shadow: 0 5px 0px #cf6517, 0 8px 15px rgba(0, 0, 0, 0.15);
    transition: all 0.1s ease;
  }

  .btn-back:hover {
    transform: translateY(2px);
    box-shadow: 0 3px 0px #cf6517, 0 5px 10px rgba(0, 0, 0, 0.15);
  }

  .hero-image-container {
    position: absolute;
    right: -40px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
  }
  
  .hero-character { 
    width: 550px; 
    height: auto; 
    object-fit: contain;
  }

  /* Bloque de Actividades */
  .category-block { margin-top: 60px; }
  
  .category-banner {
    background: #f39237; 
    color: white; 
    padding: 14px 30px; 
    border-radius: 25px;
    font-weight: 700; 
    font-size: 1.15rem; 
    text-align: center; 
    margin-bottom: 50px;
  }
  
  .cards-grid {
    display: flex; 
    gap: 35px; 
    justify-content: space-between;
  }

  .activity-card-container {
    width: 31%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
  }

  .activity-card {
    background: #ffffff; 
    border-radius: 28px; 
    width: 100%;
    box-shadow: 0 12px 35px rgba(0, 0, 0, 0.07); 
    border: 1px solid #f2f2f2;
    overflow: hidden; 
    display: flex;
    flex-direction: column;
    margin-bottom: -18px; 
    min-height: 420px;
  }

  .card-image-wrapper {
    width: 100%;
    height: 200px;
    overflow: hidden;
  }
  
  .card-image-placeholder {
    width: 100%; 
    height: 100%; 
    background: #d4d4d4; 
  }

  .card-info {
    padding: 25px 20px 30px 20px;
    text-align: center;
  }

  .card-info h3 {
    font-size: 1.3rem;
    margin-bottom: 12px;
    font-weight: 700;
  }

  .text-orange-title { color: #f07f3e; }
  .text-yellow-title { color: #ebba34; }

  .card-info p {
    font-size: 0.9rem;
    color: #555;
    line-height: 1.5;
    margin: 0;
    font-weight: 400;
  }

  .btn-view {
    border: none;
    padding: 10px 0;
    width: 140px;
    border-radius: 10px;
    font-weight: 700;
    font-size: 0.95rem;
    color: white;
    cursor: pointer;
    z-index: 3;
    transition: transform 0.1s ease;
  }

  .btn-view:hover {
    transform: scale(1.05);
  }

  .bg-orange-btn {
    background-color: #f07f3e;
    box-shadow: 0 4px 0px #cf6517;
  }

  .bg-yellow-btn {
    background-color: #fcd054;
    box-shadow: 0 4px 0px #dca51a;
  }

  /* Ajustes para el contenedor de la estrella (Aumentado de tamaño y desplazado) */
  .star-badge {
    position: absolute;
    top: -26px;
    right: -26px;
    z-index: 10;
    width: 95px;
    height: 95px;
  }

  /* Dimensiones escaladas obligatorias de la estrella */
  .star-graphic {
    width: 100% !important;
    height: auto !important;
    object-fit: contain;
    filter: drop-shadow(0px 4px 8px rgba(0,0,0,0.15));
  }
</style>
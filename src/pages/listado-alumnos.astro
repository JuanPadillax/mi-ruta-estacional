---
// src/pages/listado-alumnos.astro
import Layout from '../layouts/Layout.astro';
---

<Layout title="Listado de Alumnos - Mi Ruta Estacional">
  <div class="page-container">
    
    <main class="alumnos-page">
      <div class="alumnos-cabecera-flujo">
        <a href="/mi-perfil-pedagogico" class="btn-back">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="back-icon-svg">
            <path d="M19 12H5M5 12L12 19M5 12L12 5" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Volver a mi Perfil
        </a>
        <h1 class="page-title">Listado de Alumnos</h1>
        <h2 class="page-subtitle">Nivel Medio Mayor — Año Pedagógico 2026</h2>
      </div>

      <section class="alumnos-section">
        <div class="section-banner-orange">
          <div class="banner-content">
            <span class="students-icon">🎒</span>
            <div class="banner-text">
              <h3>Registro de Matrícula</h3>
              <p>12 alumnos registrados activos</p>
            </div>
          </div>
        </div>

        <div class="table-controls">
          <div class="controls-left">
            <span class="selected-counter" id="selectedCounter">0 alumnos seleccionados</span>
          </div>
          <div class="controls-right">
            <button class="btn-control-secondary" id="btnEditTable">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="icon">
                <path d="M12 15C13.6569 15 15 13.6569 15 12C15 10.3431 13.6569 9 12 9C10.3431 9 9 10.3431 9 12C9 13.6569 10.3431 15 12 15Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              Editar Tabla
            </button>
            <button class="btn-control-primary" id="btnAddStudent">
              <div class="plus-circle">+</div>
              Agregar Alumno
            </button>
          </div>
        </div>

        <div class="table-container">
          <table class="students-table" id="studentsTable">
            <thead>
              <tr>
                <th class="col-checkbox">
                  <input type="checkbox" id="selectAll" class="custom-checkbox" />
                </th>
                <th class="col-num">N°</th>
                <th class="col-name">Nombre de Alumno</th>
                <th class="col-guardian">Apoderado Asociado</th>
                <th class="col-code">Código de Acceso</th>
                <th class="col-progress">Bitácora (Progreso)</th>
                <th class="col-chat">Chat con Apoderado</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><input type="checkbox" class="student-select custom-checkbox" /></td>
                <td class="num-cell">1</td>
                <td class="student-name-cell">Felipe Eduardo Sepúlveda Cáceres</td>
                <td>Cesar Sepúlveda</td>
                <td>
                  <div class="code-wrapper">
                    <span class="access-code">RUT-BMD94</span>
                    <button class="btn-copy" data-code="RUT-BMD94" title="Copiar código">
                      <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="copy-icon">

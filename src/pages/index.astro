---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Methodology from '../components/Methodology.astro';
import Activities from '../components/Activities.astro';
import Archive from '../components/Archive.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Mi Ruta Estacional - Aprender Jugando">
  <!-- Barra de navegación superior (Logo e Icono de usuario) -->
  <Header />
  
  <main>
    <!-- Sección Principal (Título, descripción, botones y niño.png) -->
    <Hero />
    
    <!-- Cuatro momentos continuos (Lupa, lápiz, archivador y estrella) -->
    <Methodology />
    
    <!-- Actividades de aprendizaje (Tarjetas de colores y niños.png) -->
    <Activities />
    
    <!-- Tomos del año (Zorro, Chungungo, Vizcacha y Coipo) -->
    <Archive />
  </main>

  <!-- Pie de página con créditos y enlaces legales -->
  <Footer />
</Layout>

<style>
  /* Espaciado general opcional para separar visualmente las secciones del main */
  main {
    display: flex;
    flex-direction: column;
    gap: 40px; /* Asegura una transición fluida y aireada entre cada sección */
  }
</style>